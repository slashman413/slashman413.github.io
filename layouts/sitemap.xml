{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{- range .Data.Pages }}
  <url><loc>{{ .Permalink }}</loc>{{ if not .Lastmod.IsZero }}<lastmod>{{ .Lastmod.Format "2006-01-02" }}</lastmod>{{ end }}{{ with .Sitemap.ChangeFreq }}<changefreq>{{ . }}</changefreq>{{ end }}{{ if ge .Sitemap.Priority 0.0 }}<priority>{{ .Sitemap.Priority }}</priority>{{ end }}</url>
{{- end }}
{{- /* static tool apps live in static/ and aren't Hugo pages — list them explicitly so they stay indexed */}}
{{- range slice "utm-builder" "cron-expression-generator" "youtube-thumbnail-downloader" "tools" "popular" "saas" "services" }}
  <url><loc>{{ printf "https://slashmantools.us/%s/" . }}</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
{{- end }}
</urlset>
